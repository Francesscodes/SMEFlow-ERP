{
  "name": "SME Expense Claim",
  "doctype": "DocType",
  "module": "SMEFlow HR",
  "is_submittable": 1,
  "track_changes": 1,
  "title_field": "employee",
  "fields": [
    {"fieldname": "employee", "fieldtype": "Link", "label": "Employee", "options": "SME Employee", "reqd": 1, "in_list_view": 1},
    {"fieldname": "expense_date", "fieldtype": "Date", "label": "Expense Date", "reqd": 1},
    {"fieldname": "expense_category", "fieldtype": "Select", "label": "Category", "options": "Travel\nAccommodation\nMeals\nSupplies\nCommunication\nOther", "reqd": 1, "in_list_view": 1},
    {"fieldname": "amount", "fieldtype": "Currency", "label": "Amount", "reqd": 1, "in_list_view": 1},
    {"fieldname": "description", "fieldtype": "Small Text", "label": "Description"},
    {"fieldname": "receipt_attached", "fieldtype": "Check", "label": "Receipt Attached"},
    {"fieldname": "status", "fieldtype": "Select", "label": "Status", "options": "Draft\nPending Approval\nApproved\nRejected\nPaid", "default": "Draft", "in_list_view": 1},
    {"fieldname": "approved_by", "fieldtype": "Link", "label": "Approved By", "options": "User"},
    {"fieldname": "remarks", "fieldtype": "Small Text", "label": "Remarks"}
  ],
  "permissions": [
    {"role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1, "submit": 1}
  ]
}
