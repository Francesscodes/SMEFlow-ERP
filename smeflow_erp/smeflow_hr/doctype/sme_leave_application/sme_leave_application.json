{
  "name": "SME Leave Application",
  "doctype": "DocType",
  "module": "SMEFlow HR",
  "is_submittable": 1,
  "track_changes": 1,
  "title_field": "employee",
  "fields": [
    {"fieldname": "employee", "fieldtype": "Link", "label": "Employee", "options": "SME Employee", "reqd": 1, "in_list_view": 1},
    {"fieldname": "leave_type", "fieldtype": "Select", "label": "Leave Type", "options": "Annual Leave\nSick Leave\nMaternity Leave\nPaternity Leave\nUnpaid Leave", "reqd": 1, "in_list_view": 1},
    {"fieldname": "from_date", "fieldtype": "Date", "label": "From Date", "reqd": 1},
    {"fieldname": "to_date", "fieldtype": "Date", "label": "To Date", "reqd": 1},
    {"fieldname": "total_days", "fieldtype": "Int", "label": "Total Days"},
    {"fieldname": "reason", "fieldtype": "Small Text", "label": "Reason"},
    {"fieldname": "status", "fieldtype": "Select", "label": "Status", "options": "Open\nApproved\nRejected", "default": "Open", "in_list_view": 1},
    {"fieldname": "approved_by", "fieldtype": "Link", "label": "Approved By", "options": "User"}
  ],
  "permissions": [
    {"role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1, "submit": 1}
  ]
}
